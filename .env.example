# ── Connexion Strava (streak en direct) ──────────────────────────────────
# Copie ces variables dans Vercel (Project → Settings → Environment Variables).
# Tant qu'elles sont absentes, le site affiche la valeur manuelle de
# src/data/site.js. Voir le guide : docs/strava-setup.md

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ── Réglages du défi (optionnels — valeurs par défaut ci-dessous) ─────────
# STREAK_MIN_KM=5
# STREAK_TZ=Europe/Paris
# STREAK_START=2026-01-01

# ── Supabase (newsletter + carnet de bord + easter eggs du calculateur) ───
# Mêmes variables pour plusieurs usages, sur le même projet Supabase :
#   - Newsletter : enregistre les inscrits via /api/subscribe.
#     Voir docs/newsletter-setup.md
#   - Carnet de bord : lit les jours spéciaux via /api/journal (tables
#     journal_categories + journal_entries). Voir docs/carnet-setup.md
#   - Calculateur d'allure : lit les easter eggs via /api/pace-easter-eggs
#     (table pace_easter_eggs). Voir docs/pace-easter-eggs-setup.md
# La service_role key reste côté serveur uniquement (jamais exposée au navigateur).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
