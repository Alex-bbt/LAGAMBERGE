      ║  Easter egg #2 débloqué. Retourne courir maintenant.          ║
      ╚══════════════════════════════════════════════════════════════╝
    -->
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
