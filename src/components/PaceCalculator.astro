---
import TimeField from './coureur/TimeField.astro';
// Calculateur universel Distance / Allure / Temps.
// Fonctionne dans tous les sens : dès que 2 champs sur 3 sont remplis, le
// 3e se calcule tout seul, en temps réel (pas de bouton « Calculer »).
// Allure et temps se saisissent en cases séparées (min/sec, h/min/sec) — pas
// de « : » à taper, clavier numérique sur mobile.
// Les easter eggs d'allure sont lus dynamiquement depuis /api/pace-easter-eggs
// (table Supabase `pace_easter_eggs`) — rien n'est codé en dur.

// Raccourcis de distance courants (km). Saisie libre possible aussi.
const presets = [
  { label: '5 km', km: 5 },
  { label: '10 km', km: 10 },
  { label: 'Semi', km: 21.1 },
  { label: 'Marathon', km: 42.195 },
];
---

<div class="calc card">
  <div class="calc-head">
    <span class="eyebrow">Outil coureur</span>
    <h2>Calculateur d'allure</h2>
    <p class="calc-sub">
      Remplis deux cases, la troisième se remplit toute seule. Distance, allure,
      temps : dans le sens que tu veux, en direct. Pas de bouton à cliquer.
    </p>
  </div>

  <div class="presets" role="group" aria-label="Distances courantes">
    {presets.map((p) => (
      <button type="button" class="chip" data-km={p.km}>{p.label}</button>
    ))}
  </div>

  <form class="calc-grid" id="calc" novalidate autocomplete="off">
    <div class="field">
      <label for="f-distance">Distance</label>
      <div class="input-wrap">
        <input
          type="text"
          id="f-distance"
          inputmode="decimal"
          placeholder="10"
          aria-describedby="hint-distance"
        />
        <span class="suffix">km</span>
      </div>
      <span class="hint" id="hint-distance">ex : 10 — ou 21.1</span>
    </div>

    <div class="field">
      <label>Allure <span class="unit-hint">min/km</span></label>
      <TimeField id="f-pace" mode="pace" />
    </div>

    <div class="field">
      <label>Temps total</label>
      <TimeField id="f-time" mode="time" />
    </div>
  </form>

  <div class="calc-foot">
    <button type="button" class="btn btn--ghost" id="calc-reset">↺ Réinitialiser</button>
    <p class="calc-err" id="calc-err" role="alert" aria-live="polite" hidden></p>
  </div>

  <!-- Easter eggs : messages surprise qui apparaissent discrètement -->
  <div class="eggs" id="calc-eggs" aria-live="polite"></div>
</div>

<style>
  .calc {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, #fff 0%, var(--cream) 100%);
  }
  .calc-head { max-width: 60ch; }
  .calc-head h2 { font-size: clamp(1.6rem, 4.5vw, 2.4rem); margin: 0.6rem 0 0.5rem; }
  .calc-sub { margin: 0; color: var(--ink-soft); }

  .presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0 1.25rem;
  }
  .chip {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 2.5px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
  }
  .chip:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--ink); }
  .chip:active { transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--ink); }
  .chip.is-active { background: var(--sun); }

  .calc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
    gap: 1.25rem 1rem;
    align-items: start;
  }
  .field { display: flex; flex-direction: column; gap: 0.5rem; }
  .field label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .unit-hint { color: var(--ink-soft); font-weight: 700; font-size: 0.8rem; }
  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-wrap input {
    width: 100%;
    min-width: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    padding: 0.7rem 3.4rem 0.7rem 0.9rem;
    border-radius: var(--radius);
    border: 2.5px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    box-shadow: var(--shadow-sm);
  }
  .input-wrap input:focus {
    outline: 3px solid var(--teal);
    outline-offset: 1px;
  }
  /* Un champ calculé automatiquement se teinte pour bien montrer le sens */
  .input-wrap input.is-computed {
    background: color-mix(in srgb, var(--teal) 16%, var(--paper));
    border-style: dashed;
  }
  .suffix {
    position: absolute;
    right: 0.85rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--ink-soft);
    pointer-events: none;
  }
  .hint { font-size: 0.78rem; color: var(--ink-soft); }
  .input-wrap input.is-invalid { outline: 3px solid var(--tomato); outline-offset: 1px; }

  .calc-foot {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .calc-err {
    margin: 0;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--tomato);
  }

  .eggs { display: grid; gap: 0.6rem; margin-top: 1.25rem; }
  .egg {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    border: 2.5px solid var(--ink);
    background: var(--sun);
    font-weight: 600;
    box-shadow: var(--shadow-sm);
    animation: egg-in 0.35s ease;
  }
  .egg .egg-emoji { font-size: 1.2rem; line-height: 1.4; }
  @keyframes egg-in {
    from { opacity: 0; transform: translateY(6px) rotate(-1deg); }
    to { opacity: 1; transform: translateY(0) rotate(-0.6deg); }
  }

  @media (max-width: 680px) {
    .calc-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { initTimeField } from '../../lib/running/timefield.mjs';

  // ── Références DOM ────────────────────────────────────────────────────────
  const distEl = document.getElementById('f-distance');
  const paceEl = initTimeField(document.getElementById('f-pace')); // allure (min/sec) -> sec/km
  const timeEl = initTimeField(document.getElementById('f-time')); // temps (h/min/sec) -> sec
  const errEl = document.getElementById('calc-err');
  const eggsEl = document.getElementById('calc-eggs');
  const resetBtn = document.getElementById('calc-reset');
  const chips = Array.from(document.querySelectorAll('.chip'));

  const els = { distance: distEl, pace: paceEl, time: timeEl };

  // Ordre des champs édités par l'utilisateur, du plus récent au plus ancien.
  // Le champ en position 2 (le moins récemment touché) est celui qu'on calcule.
  let order = ['time', 'pace', 'distance'];

  // ── Lecture / écriture des valeurs ────────────────────────────────────────
  function parseDistance(v) {
    const s = String(v || '').trim().replace(',', '.');
    if (!s) return null;
    const n = Number(s);
    return Number.isFinite(n) && n > 0 ? n : NaN; // km
  }
  function formatDistance(km) {
    const rounded = Math.round(km * 1000) / 1000;
    return String(rounded).replace('.', ',');
  }

  // Valeurs courantes : distance (km), pace (sec/km), time (sec). null = vide.
  function currentValues() {
    return {
      distance: parseDistance(distEl.value),
      pace: paceEl._getSeconds(),
      time: timeEl._getSeconds(),
    };
  }

  function markComputed(name, on) { els[name].classList.toggle('is-computed', on); }
  function clearComputedFlag(name) { els[name].classList.remove('is-computed'); }

  // Écrit une valeur calculée dans le bon champ (sans réémettre d'événement).
  function writeComputed(name, value) {
    if (name === 'distance') distEl.value = formatDistance(value);
    else if (name === 'pace') paceEl._setSeconds(value, { silent: true });
    else if (name === 'time') timeEl._setSeconds(value, { silent: true });
    markComputed(name, true);
  }

  function markInvalid(vals) {
    // Seule la distance se saisit librement : c'est le seul champ « invalidable ».
    const bad = Number.isNaN(vals.distance);
    distEl.classList.toggle('is-invalid', bad);
    errEl.hidden = !bad;
    if (bad) errEl.textContent = "Hmm, cette distance n'a pas l'air d'un nombre. (ex : 10 ou 21.1)";
    return bad;
  }

  function recompute() {
    const vals = currentValues();
    markInvalid(vals);

    // La cible = le champ le moins récemment édité par l'utilisateur.
    const target = order[2];
    const sources = order.slice(0, 2);

    // Les deux sources doivent être remplies ET valides (nombre > 0).
    const ready = sources.every((n) => typeof vals[n] === 'number' && !Number.isNaN(vals[n]) && vals[n] > 0);

    if (!ready) {
      clearComputedFlag(target);
      runEasterEggs(vals);
      return;
    }

    if (target === 'time') writeComputed('time', vals.distance * vals.pace);
    else if (target === 'pace') writeComputed('pace', vals.time / vals.distance);
    else if (target === 'distance') writeComputed('distance', vals.time / vals.pace);

    // Pour les easter eggs on réévalue avec les valeurs à jour (dont la cible).
    runEasterEggs(currentValues());
  }

  // ── Easter eggs (lus dynamiquement depuis Supabase) ───────────────────────
  // Un seul chargement partagé de la table pace_easter_eggs.
  const eggsData =
    fetch('/api/pace-easter-eggs', { headers: { Accept: 'application/json' } })
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => (d && Array.isArray(d.eggs) ? d.eggs : []))
      .catch(() => []);

  function distanceMatches(egg, distanceKm) {
    if (egg.distance_m === null || egg.distance_m === undefined) return true;
    if (typeof distanceKm !== 'number' || Number.isNaN(distanceKm)) return false;
    const distM = distanceKm * 1000;
    // Tolérance : la plus grande entre 50 m et 1 % (pour 21.1 vs 21.0975 km…).
    const tol = Math.max(50, egg.distance_m * 0.01);
    return Math.abs(distM - egg.distance_m) <= tol;
  }

  function renderEggs(list, distanceKm) {
    eggsEl.innerHTML = '';
    const emojis = ['💡', '👀', '😏', '🔥', '🏃'];
    list.forEach((msg, i) => {
      const distStr =
        typeof distanceKm === 'number' && !Number.isNaN(distanceKm)
          ? formatDistance(distanceKm)
          : '';
      const text = String(msg).replace(/\{distance\}/g, distStr);
      const el = document.createElement('div');
      el.className = 'egg';
      const emoji = document.createElement('span');
      emoji.className = 'egg-emoji';
      emoji.setAttribute('aria-hidden', 'true');
      emoji.textContent = emojis[i % emojis.length];
      const span = document.createElement('span');
      span.textContent = text;
      el.appendChild(emoji);
      el.appendChild(span);
      eggsEl.appendChild(el);
    });
  }

  function runEasterEggs(vals) {
    const pace = vals.pace;
    const distanceKm = vals.distance;
    // On ne déclenche que si l'allure est connue et valide.
    if (typeof pace !== 'number' || Number.isNaN(pace)) {
      eggsEl.innerHTML = '';
      return;
    }
    eggsData.then((eggs) => {
      // (Ré)évalue avec les valeurs les plus récentes au moment de la réponse.
      const now = currentValues();
      const p = now.pace;
      const d = now.distance;
      if (typeof p !== 'number' || Number.isNaN(p)) {
        eggsEl.innerHTML = '';
        return;
      }
      const hits = eggs
        .filter((e) => p >= e.pace_min && p <= e.pace_max && distanceMatches(e, d))
        .map((e) => e.message);
      renderEggs(hits, d);
    });
  }

  // ── Entrées utilisateur ───────────────────────────────────────────────────
  function onUserEdit(name) {
    // L'utilisateur retouche un champ → il redevient une « source » prioritaire.
    clearComputedFlag(name);
    order = [name, ...order.filter((n) => n !== name)];
    recompute();
  }

  // Les widgets d'allure/temps émettent « input » quand l'utilisateur agit
  // (les écritures calculées sont « silencieuses » → aucune boucle).
  paceEl.addEventListener('input', () => onUserEdit('pace'));
  timeEl.addEventListener('input', () => onUserEdit('time'));

  // Distance : saisie libre → maj de l'état du chip actif + recalcul.
  distEl.addEventListener('input', () => {
    const val = String(distEl.value).replace(',', '.');
    chips.forEach((c) => c.classList.toggle('is-active', c.dataset.km === val));
    onUserEdit('distance');
  });

  // Raccourcis de distance
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      distEl.value = String(chip.dataset.km).replace('.', ',');
      chips.forEach((c) => c.classList.toggle('is-active', c === chip));
      onUserEdit('distance');
    });
  });

  // Réinitialiser
  resetBtn.addEventListener('click', () => {
    distEl.value = '';
    distEl.classList.remove('is-computed', 'is-invalid');
    paceEl._setSeconds(null, { silent: true });
    paceEl.classList.remove('is-computed');
    timeEl._setSeconds(null, { silent: true });
    timeEl.classList.remove('is-computed');
    chips.forEach((c) => c.classList.remove('is-active'));
    order = ['time', 'pace', 'distance'];
    errEl.hidden = true;
    eggsEl.innerHTML = '';
    distEl.focus();
  });
</script>
