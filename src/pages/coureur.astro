---
import Base from '../layouts/Base.astro';
import PaceCalculator from '../components/PaceCalculator.astro';
import WorkoutLibrary from '../components/WorkoutLibrary.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Base
  title="Espace coureur"
  description="La boîte à outils du coureur La Gamberge : un calculateur d'allure (distance, allure, temps) et une bibliothèque de séances à personnaliser et exporter vers ta montre (.FIT)."
>
  <section class="section">
    <div class="wrap">
      <header class="page-head">
        <span class="eyebrow">Espace coureur</span>
        <h1>La boîte à outils du coureur</h1>
        <p class="lede">
          Deux outils bien pratiques pour courir sans se prendre la tête : un
          <strong>calculateur d'allure</strong> pour convertir distance, allure
          et temps dans tous les sens, et une <strong>bibliothèque de séances</strong>
          à régler à ta main puis télécharger pour ta montre. Zéro compte à créer.
        </p>
      </header>

      <PaceCalculator />
    </div>
  </section>

  <!-- Bibliothèque de séances (section autonome, ancre #seances) -->
  <WorkoutLibrary />

  <section class="section">
    <div class="wrap">
      <Newsletter />
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 62ch; margin-bottom: 2rem; }
  .page-head h1 { font-size: clamp(2.2rem, 6vw, 3.4rem); margin: 1rem 0 0.75rem; }
  .lede { color: var(--ink-soft); font-size: 1.05rem; }
</style>
